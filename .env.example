# Copy to .env.local and fill in your keys (never commit .env or .env.local)

# Google Gemini — refine, summarize, enhance, story, emotion, conversational-refine
GEMINI_API_KEY=

# ElevenLabs — text-to-speech (generate-voice)
ELEVENLABS_API_KEY=

# NewsAPI — news route (optional; omit or use "demo" for limited demo mode)
NEWS_API_KEY=

# OpenWeather or compatible — weather route (optional; omit or use "demo" for placeholder)
WEATHER_API_KEY=

# Local Ollama — conversational-response, analyze-audio-silence (optional)
OLLAMA_HOST=http://localhost:11434

# --- Spotify MCP (mcp/spotify-mcp) — optional; configure in Cursor MCP settings, not Next.js
# Developer diagnostics + read .env.example via MCP
# SPOTIFY_MCP_DEVELOPER=1
# Override repo root if the server runs outside the project
# SPOTIFY_MCP_PROJECT_ROOT=

# Spotify Web API (Dashboard app) — client-credentials search only for spotify_web_search
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
